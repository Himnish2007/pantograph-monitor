# ===== Server =====
PORT=3000
NODE_ENV=production
JWT_SECRET=change_this_to_a_long_random_secret_in_production

# ===== First admin bootstrap =====
# On first startup, if no users exist yet, the server creates one admin
# account from these two values (then ignores them - safe to leave set).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_to_a_strong_password

# ===== Modbus Connection (via RUT200 Modbus TCP-to-RTU gateway) =====
# RUT200 configured in Modbus Gateway mode forwards TCP requests to the
# RS485 field bus where the sensor transmitters / PLC live.
MODBUS_MODE=TCP
MODBUS_HOST=192.168.1.1
MODBUS_PORT=502
MODBUS_UNIT_ID=1
MODBUS_POLL_INTERVAL_MS=2000
MODBUS_TIMEOUT_MS=1500

# If MODBUS_MODE=RTU (direct serial, e.g. USB-RS485 dongle on the server itself)
MODBUS_SERIAL_PATH=COM4
MODBUS_BAUD_RATE=9600

# ===== Register Map =====
# Holding registers (function code 03). Adjust to match actual transmitter/PLC map.
# Each sensor: register address + scale factor (raw_value / SCALE = engineering unit)
REG_CONTACT_FORCE=0
REG_CONTACT_FORCE_SCALE=10
REG_CARBON_STRIP_WEAR=1
REG_CARBON_STRIP_WEAR_SCALE=100
REG_HEIGHT=2
REG_HEIGHT_SCALE=10
REG_CURRENT=3
REG_CURRENT_SCALE=10

# ===== Thresholds (defaults, editable via Admin UI) =====
CONTACT_FORCE_MIN_N=60
CONTACT_FORCE_MAX_N=140
CARBON_STRIP_WEAR_WARN_PCT=70
CARBON_STRIP_WEAR_CRITICAL_PCT=90
HEIGHT_MIN_MM=1200
HEIGHT_MAX_MM=1950
CURRENT_MAX_A=1200

# ===== Pantograph Unit Identity (single unit POC) =====
UNIT_ID=PANTO-001
UNIT_LOCO_NO=WAP7-00000
UNIT_LOCATION=Depot
